{{> layout/header}}

<div class="container my-5">
    <div class="border-bottom pb-3 mb-4">
        <h1 class="display-5 fw-bold">{{board.title}}</h1>
        <div class="d-flex justify-content-between align-items-center text-muted">
            <div>
                <span class="me-3">
                    <i class="bi bi-person-circle"></i> <strong>작성자:</strong> {{board.username}}
                </span>
            </div>

            {{#board.isOwner}}
                <div class="d-flex gap-2">
                    <a href="/board/{{board.id}}/update-form" class="btn btn-outline-warning btn-sm shadow-sm">수정</a>
                    <form action="/board/{{board.id}}/delete" method="post" onsubmit="return confirm('정말 삭제하시겠습니까?');">
                        <button type="submit" class="btn btn-outline-danger btn-sm shadow-sm">삭제</button>
                    </form>
                </div>
            {{/board.isOwner}}
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-5">
        <div class="card-body p-4" style="min-height: 400px; background-color: #fafafa;">
            <div class="card-text fs-5" style="white-space: pre-wrap; line-height: 1.8;">{{board.content}}</div>
        </div>
    </div>

    <div class="text-center">
        <a href="/" class="btn btn-dark btn-lg px-5 shadow">목록으로 돌아가기</a>
    </div>
</div>

{{> layout/footer}}