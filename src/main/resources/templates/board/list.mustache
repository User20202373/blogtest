{{>layout/header}}

<div class="row mb-5">
    <div class="col text-center">
        <h1 class="display-5 fw-bold" style="color: var(--text-primary);">전체 게시글</h1>
        <p class="text-secondary">TEST 블로그의 새로운 소식을 확인하세요.</p>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {{#boards}} <div class="col">
        <div class="card h-100 custom-card">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title text-truncate">{{title}}</h5>
                <h6 class="card-subtitle mb-3 text-muted">by {{username}}</h6>

                <p class="card-text text-secondary text-truncate-2 flex-grow-1">{{content}}</p>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="text-muted" style="font-size: 0.8rem;">2024.05.20</span>
                    <a href="/board/{{id}}" class="btn btn-accent btn-sm">자세히 보기</a>
                </div>
            </div>
        </div>
    </div>
    {{/boards}} </div>

{{>layout/footer}}